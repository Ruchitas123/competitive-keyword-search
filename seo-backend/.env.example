# Copy to .env in the project root (next to main.py) and fill in real values.
# Never commit .env.

# Required for Azure OpenAI
AZURE_OPENAI_API_KEY=
# Full URL with https://, or host only (https:// is added automatically)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# Use the API version shown in Azure portal for your resource (e.g. 2024-02-01 or 2024-08-01-preview)
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional
# LLM_PROVIDER=azure
